# Create a Spotify app at https://developer.spotify.com/dashboard
# Add this exact Redirect URI to the app allowlist:
# http://127.0.0.1:8765/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback

# Runtime paths. Docker Compose mounts ./data to /data.
SPOTIFY_BACKUP_DATA_DIR=/data
SPOTIFY_BACKUP_TOKEN_FILE=/data/tokens.json

# Service mode interval.
SPOTIFY_BACKUP_INTERVAL_HOURS=24

# Optional: include only specific playlist IDs, comma-separated.
SPOTIFY_BACKUP_PLAYLIST_IDS=
